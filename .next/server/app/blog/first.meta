{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/first/layout,_N_T_/blog/first/page,_N_T_/blog/first"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/blog/first/__PAGE__",
    "/blog/first",
    "/blog",
    "/_index"
  ]
}