{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/photo-feed/layout,_N_T_/photo-feed/page,_N_T_/photo-feed"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/photo-feed/__PAGE__",
    "/photo-feed/@modal/__DEFAULT__",
    "/photo-feed",
    "/_index"
  ]
}