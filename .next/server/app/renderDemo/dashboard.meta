{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/renderDemo/layout,_N_T_/renderDemo/dashboard/layout,_N_T_/renderDemo/dashboard/page,_N_T_/renderDemo/dashboard"
  },
  "segmentPaths": [
