{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/f1/f2",
        "destination": "/f1/(.)f2",
        "has": [
          {
            "type": "header",
            "key": "next-url",
            "value": "/f1(?:/.*)?"
          }
        ],
        "internal": true,
        "regex": "^/f1/f2(?:/)?$"
      },
      {
        "source": "/f3",
        "destination": "/f1/(..)f3",
        "has": [
          {
            "type": "header",
            "key": "next-url",
            "value": "/f1(?:/.*)?"
          }
        ],
        "internal": true,
        "regex": "^/f3(?:/)?$"
      },
      {
        "source": "/f4",
        "destination": "/f1/f2/(..)(..)f4",
        "has": [
          {
            "type": "header",
            "key": "next-url",
            "value": "/f1/f2(?:/.*)?"
          }
        ],
        "internal": true,
        "regex": "^/f4(?:/)?$"
      },
      {
        "source": "/f5",
        "destination": "/f1/f2/inner-f2/(...)f5",
        "has": [
          {
            "type": "header",
            "key": "next-url",
            "value": "/f1/f2/inner\\-f2(?:/.*)?"
          }
        ],
        "internal": true,
        "regex": "^/f5(?:/)?$"
      },
      {
        "source": "/photo-feed/:nxtIid",
        "destination": "/photo-feed/(.):nxtIid",
        "has": [
          {
            "type": "header",
            "key": "next-url",
            "value": "/photo\\-feed(?:/.*)?"
          }
        ],
        "internal": true,
        "regex": "^/photo\\-feed/(?<nxtIid>[^/]+?)(?:/)?$"
      }
    ],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/articles/[articleId]",
      "regex": "^/articles/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtParticleId": "nxtParticleId"
      },
      "namedRegex": "^/articles/(?<nxtParticleId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/comments/[id]",
      "regex": "^/comments/([^/]+?)(?:/)?$",
